#!/bin/bash
# Service Interconnect - setup database connectivity (idempotent)

set -euo pipefail

GREEN="[32m"
YELLOW="[33m"
RESET="[0m"

USER=$(oc whoami)
NS="${USER}-devspaces"
DB_NS="shared-database"

echo ""
echo -e "${YELLOW}=== Setting up Service Interconnect for ${USER} ===${RESET}"
echo ""

# Step 1: Create Site
echo -e "--- ${YELLOW}Step 1:${RESET} Creating Site ---"
cat <<EOF | oc apply -f -
apiVersion: skupper.io/v2alpha1
kind: Site
metadata:
  name: ${USER}-site
  namespace: ${NS}
spec:
  linkAccess: route
EOF

oc wait --for=condition=Configured site/${USER}-site -n ${NS} --timeout=120s
echo -e "${GREEN}Site configured${RESET}"

# Wait for router route to be available (needed for grant endpoint resolution)
echo "Waiting for router route..."
for i in $(seq 1 30); do
  oc get route skupper-router-inter-router -n ${NS} &>/dev/null && break
  sleep 2
done
oc wait --for=jsonpath='{.status.ingress[0].conditions[0].status}'=True route/skupper-router-inter-router -n ${NS} --timeout=120s

# Step 2: Create AccessGrant
echo ""
echo -e "--- ${YELLOW}Step 2:${RESET} Creating AccessGrant ---"
cat <<EOF | oc apply -f -
apiVersion: skupper.io/v2alpha1
kind: AccessGrant
metadata:
  name: grant-${USER}
  namespace: ${NS}
spec:
  redemptionsAllowed: 1
  expirationWindow: 168h
EOF

oc wait --for=condition=Ready accessgrant/grant-${USER} -n ${NS} --timeout=120s
echo -e "${GREEN}AccessGrant ready${RESET}"

# Step 3: Create AccessToken in shared-database
echo ""
echo -e "--- ${YELLOW}Step 3:${RESET} Creating AccessToken in ${DB_NS} ---"
URL=$(oc get accessgrant grant-${USER} -n ${NS} -o jsonpath='{.status.url}')
CODE=$(oc get accessgrant grant-${USER} -n ${NS} -o jsonpath='{.status.code}')
CA=$(oc get accessgrant grant-${USER} -n ${NS} -o jsonpath='{.status.ca}' | sed 's/^/    /')

cat <<EOF | oc apply -f -
apiVersion: skupper.io/v2alpha1
kind: AccessToken
metadata:
  name: token-${USER}
  namespace: ${DB_NS}
spec:
  url: "${URL}"
  code: "${CODE}"
  ca: |
${CA}
EOF

for i in $(seq 1 20); do
  oc get link/token-${USER} -n ${DB_NS} &>/dev/null && break
  sleep 3
done

oc wait --for=condition=Ready link/token-${USER} -n ${DB_NS} --timeout=120s
echo -e "${GREEN}Link ready${RESET}"

# Step 4: Create Listener
echo ""
echo -e "--- ${YELLOW}Step 4:${RESET} Creating Listener ---"
cat <<EOF | oc apply -f -
apiVersion: skupper.io/v2alpha1
kind: Listener
metadata:
  name: postgres-listener
  namespace: ${NS}
spec:
  routingKey: postgres
  host: postgres
  port: 5432
EOF

oc wait --for=condition=Ready listener/postgres-listener -n ${NS} --timeout=120s
echo -e "${GREEN}Listener ready${RESET}"

echo ""
si-status
